{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Web Dev - Serveur Local",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/start-dev.js",
      "console": "integratedTerminal"
    }
  ],
  "tasks": [
    {
      "label": "Démarrer serveur HTTP",
      "type": "shell",
      "command": "python3 -m http.server 8000",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Serving.*",
          "endsPattern": "^Serving.*"
        }
      }
    }
  ]
}
