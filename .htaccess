# ============================================
# .htaccess pour Andu-Xara Store
# Version: 2.0 - Optimisé SEO et Performances
# Date: 2025-12-01
# ============================================

# Activer le moteur de réécriture
RewriteEngine On

# ============================================
# 1. REDIRECTIONS HTTPS et CANONIQUE
# ============================================

# A. Rediriger HTTP vers HTTPS (TOUTES les versions)
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}/$1 [R=301,L]

# B. Rediriger WWW vers sans WWW (APRES HTTPS)
RewriteCond %{HTTP_HOST} ^www\.andu-xara\.store [NC]
RewriteRule ^(.*)$ https://andu-xara.store/$1 [R=301,L]

# ============================================
# 2. REDIRECTIONS .html VERS URLS PROPRES
# ============================================

# A. Rediriger index.html vers /
RewriteRule ^index\.(php|html?)$ / [R=301,L]

# B. Rediriger les anciennes URLs .html vers sans extension
RewriteCond %{THE_REQUEST} \s/+(.*?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# C. Rediriger les URLs avec .html à la fin
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# ============================================
# 3. REWRITE POUR SERVIR LES FICHIERS .html
# ============================================

# A. Servir les pages sans .html (URLs propres)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^\.]+)/?$ $1.html [NC,L]

# B. Servir les pages avec trailing slash
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(\.[a-zA-Z0-9]{1,5}|/)$
RewriteRule ^(.*)$ /$1/ [R=301,L]

# ============================================
# 4. REDIRECTIONS SPÉCIFIQUES DES PAGES
# ============================================

# Redirections individuelles pour compatibilité
Redirect 301 /blog.html https://andu-xara.store/blog
Redirect 301 /acheter.html https://andu-xara.store/acheter
Redirect 301 /histoire.html https://andu-xara.store/histoire
Redirect 301 /reductions.html https://andu-xara.store/reductions
Redirect 301 /faq.html https://andu-xara.store/faq
Redirect 301 /contact.html https://andu-xara.store/contact
Redirect 301 /conditions-generales.html https://andu-xara.store/conditions-generales
Redirect 301 /mentions-legales.html https://andu-xara.store/mentions-legales
Redirect 301 /politique-confidentialite.html https://andu-xara.store/politique-confidentialite
Redirect 301 /suivi-livraison.html https://andu-xara.store/suivi-livraison

# ============================================
# 5. SÉCURITÉ
# ============================================

# A. Protection contre les injections
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z])
RewriteRule ^(.*)$ - [F,L]

# B. Bloquer l'accès aux fichiers sensibles
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh|sql|env|config)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# C. Empêcher l'accès aux répertoires
Options -Indexes

# D. Headers de sécurité
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "camera=(), microphone=(), geolocation=()"
    
    # CORS pour les fonts
    <FilesMatch "\.(ttf|otf|eot|woff2?)$">
        Header set Access-Control-Allow-Origin "*"
    </FilesMatch>
</IfModule>

# ============================================
# 6. PERFORMANCE ET CACHE
# ============================================

# A. Compression GZIP
<IfModule mod_deflate.c>
    # Active la compression
    SetOutputFilter DEFLATE
    
    # Compresse ces types de fichiers
    AddOutputFilterByType DEFLATE text/html text/plain text/xml
    AddOutputFilterByType DEFLATE text/css text/javascript application/javascript
    AddOutputFilterByType DEFLATE application/json application/xml application/rss+xml
    AddOutputFilterByType DEFLATE image/svg+xml
    
    # Exceptions pour les navigateurs anciens
    BrowserMatch ^Mozilla/4 gzip-only-text/html
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
</IfModule>

# B. Cache navigateur (Expires Headers)
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images - Cache 1 an
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType image/avif "access plus 1 year"
    
    # CSS et JavaScript - Cache 1 mois
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # Fonts - Cache 1 an
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/otf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    
    # HTML - Pas de cache (toujours frais)
    ExpiresByType text/html "access plus 0 seconds"
    
    # XML - Cache 1 heure
    ExpiresByType application/xml "access plus 1 hour"
    ExpiresByType text/xml "access plus 1 hour"
</IfModule>

# C. Keep-Alive
<IfModule mod_headers.c>
    Header set Connection keep-alive
</IfModule>

# ============================================
# 7. CONFIGURATION TYPE MIME
# ============================================

# A. Types MIME pour fichiers spéciaux
<Files "sitemap.xml">
    ForceType application/xml
    Header set Content-Type "application/xml; charset=utf-8"
</Files>

<Files "robots.txt">
    ForceType text/plain
    Header set Content-Type "text/plain; charset=utf-8"
</Files>

<Files "manifest.json">
    ForceType application/json
    Header set Content-Type "application/json; charset=utf-8"
</Files>

# B. Types MIME standards
AddType text/html .html
AddType text/css .css
AddType text/javascript .js
AddType application/javascript .js
AddType image/x-icon .ico
AddType image/svg+xml .svg
AddType application/json .json
AddCharset UTF-8 .html .css .js .json .xml

# ============================================
# 8. GESTION DES ERREURS
# ============================================

# A. Pages d'erreur personnalisées
ErrorDocument 400 /erreur.html
ErrorDocument 401 /erreur.html
ErrorDocument 403 /erreur.html
ErrorDocument 404 /erreur.html
ErrorDocument 500 /erreur.html
ErrorDocument 503 /erreur.html

# B. Redirection des anciennes erreurs
Redirect 301 /404.html https://andu-xara.store/
Redirect 301 /500.html https://andu-xara.store/

# ============================================
# 9. OPTIMISATION SEO
# ============================================

# A. Trailing slash pour les URLs
RewriteCond %{REQUEST_URI} /+[^\.]+$
RewriteRule ^(.+[^/])$ %{REQUEST_URI}/ [R=301,L]

# B. Éviter le contenu dupliqué (sans WWW et sans .html)
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^(.*)/index\.(html|php)$ /$1/ [R=301,L]

# C. Supprimer les paramètres inutiles
RewriteCond %{QUERY_STRING} ^(\d+)=\d+$
RewriteRule ^(.*)$ /$1? [R=301,L]

# ============================================
# 10. PROTECTION CONTRE LES ROBOTS MALVEILLANTS
# ============================================

# A. Blocage de bots spécifiques
SetEnvIfNoCase User-Agent "mj12bot" bad_bot
SetEnvIfNoCase User-Agent "ahrefsbot" bad_bot
SetEnvIfNoCase User-Agent "semrushbot" bad_bot
SetEnvIfNoCase User-Agent "dotbot" bad_bot
SetEnvIfNoCase User-Agent "rogerbot" bad_bot

# B. Bloquer les mauvais bots
<Limit GET POST HEAD>
    Order Allow,Deny
    Allow from all
    Deny from env=bad_bot
</Limit>

# ============================================
# 11. COMPATIBILITÉ AVEC LE SITE
# ============================================

# A. Permettre l'accès aux fichiers nécessaires
<FilesMatch "\.(jpg|jpeg|png|gif|ico|css|js|pdf|txt|svg|woff|woff2|ttf|eot)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# B. Support des URLs avec hash (pour les SPA)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ /index.html [L]

# ============================================
# 12. CONFIGURATION SPÉCIFIQUE ANDU-XARA
# ============================================

# A. Priorité des fichiers
DirectoryIndex index.html index.php

# B. Encodage par défaut
AddDefaultCharset UTF-8

# C. Désactiver ETags (meilleur pour le cache)
FileETag None
Header unset ETag

# D. Limiter la taille des téléchargements
LimitRequestBody 10485760

# ============================================
# FIN DU FICHIER .htaccess
# ============================================

# Note: Pour tester les redirections, utilisez:
# curl -I http://www.andu-xara.store/blog.html
# Devrait retourner: 301 → https://andu-xara.store/blog
